DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@localhost:5432/threadline
ACCESS_SECRET=your_access_token_secret_min_32_chars
REFRESH_SECRET=your_refresh_token_secret_min_32_chars
UPLOAD_DIR=app/static/uploads
CORS_ORIGINS=http://localhost:3000

# "development" | "production"
ENVIRONMENT=development

# Leave empty to use local filesystem storage.
# Set to your Cloudinary URL in production: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=
